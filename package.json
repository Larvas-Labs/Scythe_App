{
  "name": "scythe",
  "version": "1.0.1",
  "description": "Harvest your disk space",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm run electron:dev\"",
    "electron:dev": "node scripts/wait-and-launch.js",
    "postinstall": "node scripts/rename-electron.js",
    "build": "vite build && electron-builder",
    "publish": "vite build && electron-builder --publish always",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.scythe.app",
    "productName": "Scythe",
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }]
    },
    "dmg": {
      "title": "Scythe",
      "window": { "width": 540, "height": 380 }
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "node_modules/**/*",
      "!node_modules/.cache/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "peterhagman",
      "repo": "Scythe",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/jost": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "electron-log": "^5.4.4",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^27.3.11",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "vite": "^4.5.3",
    "wait-on": "^7.2.0"
  }
}
